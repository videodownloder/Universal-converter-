{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and active subscription tier.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth user ID." },
        "email": { "type": "string", "description": "User email address." },
        "plan": { "type": "string", "enum": ["Free", "Pro", "Ultimate"], "description": "Active subscription tier." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when user document was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when user document was last updated." }
      },
      "required": ["uid", "email", "plan", "createdAt", "updatedAt"]
    },
    "History": {
      "title": "Conversion History",
      "description": "Historical record of a file converted by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Core file task ID." },
        "name": { "type": "string", "description": "Original file name." },
        "size": { "type": "number", "description": "Original file size in bytes." },
        "type": { "type": "string", "description": "File mime type." },
        "extension": { "type": "string", "description": "Original file extension." },
        "targetFormat": { "type": "string", "description": "Target converted file extension." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the conversion happened." }
      },
      "required": ["id", "name", "size", "type", "extension", "targetFormat", "createdAt"]
    },
    "Admin": {
      "title": "System Administrator",
      "description": "Secure identifier mapping admin permissions directly.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID for admin verification." },
        "email": { "type": "string", "description": "The admin email address." }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user account profiles."
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "History",
      "description": "Conversion records database representing items generated by a user."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Permissions mapping containing verified system administrator ids."
    }
  }
}
